generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model audit_log {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  action     String?   @db.VarChar(100)
  detail     String?   @db.Text
  ip         String?   @db.VarChar(45)
  created_at DateTime? @default(now()) @db.DateTime(0)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "audit_log_ibfk_1")

  @@index([user_id], map: "user_id")
}

model devices {
  id                              String          @id @db.VarChar(20)
  owner                           String          @db.VarChar(100)
  phone                           String?         @db.VarChar(20)
  model                           String          @db.VarChar(100)
  spec                            String?         @db.VarChar(100)
  imei                            String          @db.VarChar(20)
  serial                          String?         @db.VarChar(50)
  os                              devices_os
  amount                          Decimal         @db.Decimal(10, 2)
  rate                            Decimal?        @default(3.00) @db.Decimal(5, 2)
  months                          Int?            @default(3)
  date_in                         DateTime        @db.Date
  due_date                        DateTime        @db.Date
  note                            String?         @db.Text
  mdm_pin                         String?         @db.VarChar(100)
  locked                          Boolean?        @default(false)
  status                          devices_status? @default(active)
  created_by                      Int?
  locked_by                       Int?
  locked_at                       DateTime?       @db.DateTime(0)
  created_at                      DateTime?       @default(now()) @db.DateTime(0)
  users_devices_created_byTousers users?          @relation("devices_created_byTousers", fields: [created_by], references: [id], onUpdate: Restrict, map: "devices_ibfk_1")
  users_devices_locked_byTousers  users?          @relation("devices_locked_byTousers", fields: [locked_by], references: [id], onUpdate: Restrict, map: "devices_ibfk_2")

  @@index([created_by], map: "created_by")
  @@index([locked_by], map: "locked_by")
}

model redeem_history {
  id          Int       @id @default(autoincrement())
  device_id   String    @db.VarChar(20)
  owner       String?   @db.VarChar(100)
  model       String?   @db.VarChar(100)
  amount      Decimal?  @db.Decimal(10, 2)
  interest    Decimal?  @db.Decimal(10, 2)
  total       Decimal?  @db.Decimal(10, 2)
  redeemed_by Int?
  redeemed_at DateTime? @default(now()) @db.DateTime(0)
  users       users?    @relation(fields: [redeemed_by], references: [id], onUpdate: Restrict, map: "redeem_history_ibfk_1")

  @@index([redeemed_by], map: "redeemed_by")
}

model settings {
  k String  @id @db.VarChar(50)
  v String? @db.Text
}

model users {
  id                                Int              @id @default(autoincrement())
  username                          String           @unique(map: "username") @db.VarChar(50)
  password                          String           @db.VarChar(255)
  name                              String           @db.VarChar(100)
  role                              users_role?      @default(staff)
  active                            Boolean?         @default(true)
  last_login                        DateTime?        @db.DateTime(0)
  created_at                        DateTime?        @default(now()) @db.DateTime(0)
  audit_log                         audit_log[]
  devices_devices_created_byTousers devices[]        @relation("devices_created_byTousers")
  devices_devices_locked_byTousers  devices[]        @relation("devices_locked_byTousers")
  redeem_history                    redeem_history[]
}

enum users_role {
  admin
  staff
}

enum devices_os {
  iOS
  Android
}

enum devices_status {
  active
  redeemed
}
